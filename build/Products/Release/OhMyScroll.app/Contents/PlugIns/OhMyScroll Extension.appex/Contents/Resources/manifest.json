{
  "manifest_version": 3,
  "name": "OhMyScroll",
  "version": "0.2.0",
  "description": "Firefox-style auto-scroll behavior for Safari webpages.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "OhMyScroll/ExtensionIcons/icon-16.png",
    "32": "OhMyScroll/ExtensionIcons/icon-32.png",
    "48": "OhMyScroll/ExtensionIcons/icon-48.png",
    "128": "OhMyScroll/ExtensionIcons/icon-128.png"
  },
  "action": {
    "default_title": "OhMyScroll",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "OhMyScroll/ExtensionIcons/icon-16.png",
      "32": "OhMyScroll/ExtensionIcons/icon-32.png",
      "48": "OhMyScroll/ExtensionIcons/icon-48.png",
      "128": "OhMyScroll/ExtensionIcons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "OhMyScroll/ExtensionIcons/hand-white-16.png",
        "OhMyScroll/ExtensionIcons/hand-yellow-16.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
